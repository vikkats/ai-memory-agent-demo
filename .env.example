# Copy to .env.local for local experiments.
# Do not commit real secrets.

AI_PROVIDER_BASE_URL=https://api.example.com/v1
AI_PROVIDER_API_KEY=replace-with-your-key
AI_PROVIDER_MODEL_ID=example-model

EMBEDDING_PROVIDER_BASE_URL=https://api.example.com/v1
EMBEDDING_PROVIDER_API_KEY=replace-with-your-key
EMBEDDING_MODEL_ID=example-embedding-model

QDRANT_URL=https://example-qdrant-url
QDRANT_API_KEY=replace-with-your-key
QDRANT_COLLECTION=demo_memories

# Optional scheduled check-in settings
AGENT_CHECKIN_ENABLED=false
AGENT_CHECKIN_INTERVAL_MINUTES=60
